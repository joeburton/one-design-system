{
  "name": "one-design-system",
  "version": "0.1.0",
  "description": "One Design System — token-driven, theme-aware React component library",
  "type": "module",
  "exports": {
    ".": "./components/index.ts",
    "./styles": "./styles/tokens.css",
    "./styles/dark": "./styles/themes/dark.css",
    "./styles/global": "./styles/global.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate:component": "tsx scripts/generate-component.ts",
    "tokens:validate": "tsx scripts/validate-tokens.ts",
    "tokens:build": "tsx scripts/transform-tokens.ts",
    "tokens:check": "npm run tokens:validate && npm run tokens:build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\" \"!agent-skills/**\" \"!.claude/**\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\" \"!agent-skills/**\" \"!.claude/**\""
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-interactions": "^8.4.0",
    "@storybook/react-vite": "^8.4.0",
    "@storybook/test": "^8.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "zod": "^3.23.0"
  }
}
